# ═══════════════════════════════════════════════════════════════════════════
# Production environment variables for Docker deployment.
# Copy to .env.docker and fill in real values before `docker-compose up`.
# ═══════════════════════════════════════════════════════════════════════════

# --- Application ---
LOG_LEVEL=INFO
ENVIRONMENT=production

# --- Streamlit Authentication (Rule 32) ---
# Generate hash:  python -c "import hashlib; print(hashlib.sha256(b'YourPassword').hexdigest())"
STREAMLIT_AUTH_ENABLED=true
STREAMLIT_AUTH_PASSWORD_HASH=

# --- Data Sources ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_KEY=
SEC_EDGAR_USER_AGENT=Market Analysis AI (your.email@example.com)

# --- Optional ---
FRED_API_KEY=

# --- Database paths (inside container) ---
DUCKDB_PATH=/data/market_data.duckdb
SQLITE_PATH=/data/personal.sqlite

# --- Backups ---
BACKUP_DIR=/data/backups
BACKUP_RETAIN_COUNT=10

# --- Cache ---
CACHE_DIR=/data/cache
CACHE_DEFAULT_TTL=3600

# --- Feature flags (override defaults from config/feature_flags.yaml) ---
FEATURE_OLLAMA_NARRATIVE=false
FEATURE_PYTORCH_FORECASTING=false

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
