# ═══════════════════════════════════════════════════════════════════════════
# MARKET ANALYSIS AI — v6.0 — Example environment configuration
# ═══════════════════════════════════════════════════════════════════════════
# ATTENZIONE: Mai committare il file .env reale. Solo .env.example è tracciato.
# Regola 15: Nessuna API key nel codice. .env + python-dotenv. Zero secret nei log.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Ambiente di esecuzione ────────────────────────────────────────────────
APP_ENV=development                 # development | staging | production
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                     # json (produzione) | console (sviluppo)

# ─── Database paths ────────────────────────────────────────────────────────
DUCKDB_PATH=db/market_data.duckdb
SQLITE_PATH=db/personal.sqlite

# ─── API Keys — Market Data ────────────────────────────────────────────────
# Finnhub — https://finnhub.io (free tier: 60 req/min)
FINNHUB_API_KEY=your_finnhub_key_here

# Alpha Vantage — https://www.alphavantage.co (free tier: 5 req/min)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=your_fred_key_here

# SEC EDGAR — richiede solo User-Agent identificativo
SEC_EDGAR_USER_AGENT="Your Name your_email@example.com"

# BLS — https://data.bls.gov/registrationEngine/ (opzionale, aumenta rate limit)
BLS_API_KEY=

# eToro Public API — https://api-portal.etoro.com/getting-started/authentication
# Account verified richiesto. Genera da Settings -> Trade -> Get API Keys.
# Permesso 'Read' sufficiente per leggere il portfolio.
ETORO_API_KEY=your_etoro_api_key_here
ETORO_USER_KEY=your_etoro_user_key_here

# ─── Streamlit Authentication — Regola 32 ──────────────────────────────────
# In produzione DEVE essere abilitata. In sviluppo locale può essere disattivata.
STREAMLIT_AUTH_ENABLED=false
# Hash SHA-256 della password (NON la password in chiaro).
# Generare con: python -c "import hashlib; print(hashlib.sha256(b'mypassword').hexdigest())"
STREAMLIT_AUTH_PASSWORD_HASH=

# ─── Backup Configuration ──────────────────────────────────────────────────
BACKUP_DIR=data/backups
BACKUP_RETAIN_COUNT=10
BACKUP_RETAIN_DAYS=30

# ─── Ollama (LLM locale — opzionale) ───────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# ─── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Europe/Rome
SCHEDULER_ENABLED=true

# ─── Error Budget (Regola 30) ──────────────────────────────────────────────
ERROR_BUDGET_THRESHOLD_PCT=10.0     # Sopra questa soglia → auto-sospensione
ERROR_BUDGET_WINDOW_MINUTES=5

# ─── Valuta base ───────────────────────────────────────────────────────────
BASE_CURRENCY=EUR
